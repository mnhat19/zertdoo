# ============================================================
# ZERTDOO - FILE CAU HINH BIEN MOI TRUONG
# ============================================================
# Huong dan:
# 1. Copy file nay thanh .env:  cp .env.example .env
# 2. Dien cac gia tri tuong ung ben duoi
# 3. KHONG commit file .env len git
# ============================================================

# === App ===
DEBUG=false
TIMEZONE=Asia/Ho_Chi_Minh

# === PostgreSQL ===
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://zertdoo:mat_khau_cua_ban@localhost:5432/zertdoo

# === Google APIs ===
# --- Cach 1: Dung file (chay local) ---
# Duong dan den file credentials.json (tai tu Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=credentials/credentials.json
# Duong dan den file token.json (tu dong tao sau lan xac thuc dau tien)
GOOGLE_TOKEN_PATH=credentials/token.json

# --- Cach 2: Dung base64 (chay tren Koyeb/cloud) ---
# Encode file thanh base64: base64 -w0 credentials.json
# Paste ket qua vao day. Neu co gia tri, se uu tien tao file tu base64.
GOOGLE_CREDENTIALS_BASE64=
GOOGLE_TOKEN_BASE64=

# ID cua Google Spreadsheet (lay tu URL: https://docs.google.com/spreadsheets/d/ID_O_DAY/edit)
GOOGLE_SPREADSHEET_ID=

# === Notion ===
# Tao tai: https://www.notion.so/my-integrations -> New integration -> Copy Internal Integration Secret
NOTION_TOKEN=

# === LLM ===
# Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Nhieu Gemini keys luan phien (ngan rate limit). Phan cach bang dau phay.
# VD: AIzaSy...key1,AIzaSy...key2,AIzaSy...key3
GEMINI_API_KEYS=
# Groq (fallback): https://console.groq.com/keys
GROQ_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=3

# === Telegram ===
# Tao bot: nhan tin @BotFather tren Telegram -> /newbot -> copy token
TELEGRAM_BOT_TOKEN=
# Lay chat_id: nhan tin cho bot, truy cap https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_ALLOWED_CHAT_ID=
# Secret bat ky de xac thuc webhook (tu dat, VD: mot chuoi random)
TELEGRAM_WEBHOOK_SECRET=

# === Gmail ===
GMAIL_RECIPIENT=nhatdm234112e@st.uel.edu.vn
YEAR_VISION_PATH=assets/year_vision.jpg

# === API Security ===
# Secret key de bao ve cac endpoint /api/*
# Neu de trong: cho phep truy cap tu do (dev mode)
# Neu co gia tri: yeu cau header Authorization: Bearer <key>
API_SECRET_KEY=

# === Web Push (VAPID) ===
# Dung de gui browser push notification cho thong bao dong bo.
# Tao 1 lan bang lenh:
#   pip install pywebpush
#   python -c "from py_vapid import Vapid; import base64; from cryptography.hazmat.primitives.serialization import Encoding, PublicFormat, PrivateFormat, NoEncryption; v=Vapid(); v.generate_keys(); print('PUB:', base64.urlsafe_b64encode(v.public_key.public_bytes(Encoding.X962, PublicFormat.UncompressedPoint)).rstrip(b'=').decode()); print('PRIV:', base64.urlsafe_b64encode(v.private_key.private_bytes(Encoding.DER, PrivateFormat.PKCS8, NoEncryption())).rstrip(b'=').decode())"
# Sau khi co keys, dien vao day VA len Render dashboard.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:nhatdm234112e@st.uel.edu.vn

# === Scheduler ===
# Gio chay SchedulerAgent hang ngay (gio Viet Nam)
SCHEDULER_HOUR=6
SCHEDULER_MINUTE=0

# === Server ===
HOST=0.0.0.0
PORT=8000
# URL cong khai cua server (de set webhook Telegram)
# VD: https://zertdoo.duckdns.org
WEBHOOK_BASE_URL=
